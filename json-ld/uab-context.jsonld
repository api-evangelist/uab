  "@type": "CollegeOrUniversity",
  "@id": "https://www.uab.cat/",
  "name": "Autonomous University of Barcelona",
  "url": "https://www.uab.cat/",
  "description": "Public research university in Bellaterra, near Barcelona, Spain, founded in 1968.",
  "foundingDate": "1968",
  "location": "Bellaterra, Barcelona, Spain",
  "sameAs": [
    "https://www.linkedin.com/school/uabbarcelona/",
